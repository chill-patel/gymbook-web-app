{
  "name": "@gymbook/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode staging",
    "dev:prod": "vite --mode production",
    "build": "tsc -b && vite build --mode staging",
    "build:prod": "tsc -b && vite build --mode production",
    "deploy:staging": "npm run build && firebase deploy --only hosting:staging",
    "deploy:prod": "npm run build:prod && firebase deploy --only hosting:prod",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource/poppins": "^5.1.0",
    "@hookform/resolvers": "^4.1.3",
    "@mui/icons-material": "^6.4.0",
    "@mui/material": "^6.4.0",
    "axios": "^1.7.9",
    "i18next": "^24.2.2",
    "js-cookie": "^3.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^15.4.1",
    "react-international-phone": "^4.8.0",
    "react-router": "^7.1.5",
    "recharts": "^2.15.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/js-cookie": "^3.0.6",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.1.0"
  }
}
